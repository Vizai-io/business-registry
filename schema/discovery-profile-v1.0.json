{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://vizai.io/schema/discovery-profile/v1.0",
  "title": "VizAI Discovery Profile",
  "description": "Lightweight business discovery entry for AI system consumption - the public reference layer",
  "type": "object",
  "required": ["schemaVersion", "businessIdentifier", "verification", "metadata"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Version of the VizAI Discovery Profile schema",
      "const": "1.0"
    },
    "businessIdentifier": {
      "type": "object",
      "description": "Core identifying information for discovery",
      "required": ["primaryDomain", "commonName"],
      "properties": {
        "primaryDomain": {
          "type": "string",
          "format": "hostname",
          "description": "Primary business website domain (unique identifier)"
        },
        "commonName": {
          "type": "string",
          "description": "Common name used in business"
        },
        "legalName": {
          "type": "string",
          "description": "Official registered business name"
        },
        "aliases": {
          "type": "array",
          "description": "Other names the business is known by",
          "items": {"type": "string"}
        }
      }
    },
    "category": {
      "type": "string",
      "description": "Industry category for discovery",
      "enum": ["technology", "professional-services", "financial", "healthcare", "manufacturing", "retail", "other"]
    },
    "verification": {
      "type": "object",
      "description": "Verification and data quality metadata",
      "required": ["status", "tier", "lastVerified"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["verified", "community", "pending"],
          "description": "Verification status of this entry"
        },
        "tier": {
          "type": "string",
          "enum": ["verified", "community", "enterprise"],
          "description": "VizAI service tier"
        },
        "method": {
          "type": "string",
          "enum": ["domain-ownership", "email-verification", "manual-review", "self-reported"],
          "description": "How this entry was verified"
        },
        "lastVerified": {
          "type": "string",
          "format": "date",
          "description": "Date of last verification"
        },
        "qualityScore": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Data quality score (0-100) - only available for verified/enterprise tiers"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Registry metadata",
      "required": ["dateAdded", "lastUpdated"],
      "properties": {
        "dateAdded": {
          "type": "string",
          "format": "date",
          "description": "Date added to registry"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date",
          "description": "Date of last update"
        }
      }
    }
  }
}